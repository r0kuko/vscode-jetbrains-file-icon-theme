{
  "name": "jetbrains-newui-file-icon-theme",
  "displayName": "JetBrains New UI File Icon Theme",
  "description": "JetBrains IDEs New UI inspired icon theme. Extra .kts and build.gradle.kts support.",
  "publisher": "r0kuko",
  "version": "0.1.0",
  "license": "MIT",
  "homepage": "https://github.com/r0kuko/vscode-jetbrains-file-icon-theme",
  "bugs": {
    "url": "https://github.com/r0kuko/vscode-jetbrains-file-icon-theme/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/r0kuko/vscode-jetbrains-file-icon-theme.git"
  },
  "icon": "assets/img/icon-enhanced.png",
  "engines": {
    "vscode": "^1.21.0"
  },
  "categories": [
    "Themes"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "keywords": [
    "jetbrains",
    "intellij",
    "pycharm",
    "goland",
    "rustrover",
    "webstorm",
    "idea",
    "clion",
    "phpstorm",
    "rubymiine",
    "appcode",
    "datagrip",
    "rider",
    "dataspell",
    "icons",
    "icon-theme",
    "theme",
    "new ui",
    "JetBrains Mono",
    "font",
    "cold",
    "dark",
    "material"
  ],
  "contributes": {
    "iconThemes": [
      {
        "id": "jetbrains-file-icon-theme-auto",
        "label": "| Auto | JetBrains New UI File Icon Theme",
        "path": "./themes/auto-jetbrains-icon-theme.json"
      },
      {
        "id": "jetbrains-file-icon-theme-dark",
        "label": "| Dark | JetBrains New UI File Icon Theme",
        "path": "./themes/dark-jetbrains-icon-theme.json"
      },
      {
        "id": "jetbrains-file-icon-theme-light",
        "label": "| Light | JetBrains New UI File Icon Theme",
        "path": "./themes/light-jetbrains-icon-theme.json"
      }
    ],
    "configuration": {
      "title": "JetBrains File Icon Theme",
      "properties": {
        "jetbrains-file-icon-theme.enableGoTestIcons": {
          "type": "boolean",
          "default": false,
          "description": "Experimental: Enable special icons for Go test files (*_test.go)"
        },
        "jetbrains-file-icon-theme.enableKotlinContentIcons": {
          "type": "boolean",
          "default": true,
          "description": "Enable content-aware icons for Kotlin files (.kt)"
        }
      }
    },
    "commands": [
      {
        "command": "jetbrains-file-icon-theme.updateGoTestIcons",
        "title": "Update Go Test Icons (experimental)"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:jetbrains-file-icon-theme.updateGoTestIcons",
    "onLanguage:go",
    "onLanguage:kotlin"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepackage": "npm run test && npm run compile",
    "validate:manifest": "node scripts/validate-manifest.js",
    "validate": "node scripts/validate-icon-themes.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/vsce": "^3.0.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
